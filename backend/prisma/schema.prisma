model Internship {
  id             Int              @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  companyName    String
  companyAddress String?
  companyLatitude Float?
  companyLongitude Float?
  mentorName     String?
  mentorPhone    String?
  mentorEmail    String?
  accessCode     String?          @unique
  accessCodeExpiresAt DateTime?
  teacherId      Int?
  startDate      DateTime?
  endDate        DateTime?
  status         InternshipStatus @default(PROPOSED)
  finalGrade     Float?
  certificateUrl String?
  acceptanceLetterUrl String?
  rejectionReason     String?
  
  // Report Fields
  reportTitle     String?
  reportUrl       String?
  schoolApprovalDate String?  // Added for approval sheet date
  lastActiveTab      String?  // Added for UI persistence
  examinerId      Int?
  defenseDate     DateTime?
  defenseRoom     String?
  
  // Detailed Scores
  scorePresentation  Float?
  scoreUnderstanding Float?
  scoreRelevance     Float?
  scoreSystematics   Float?
  
  defenseScore    Float?
  defenseNotes    String?
  
  // Industry Score (70%)
  industryScore   Float?

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student        User             @relation("StudentInternship", fields: [studentId], references: [id])
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  teacher        User?            @relation("TeacherInternship", fields: [teacherId], references: [id])
  examiner       User?            @relation("ExaminerInternship", fields: [examinerId], references: [id])
  journals       InternshipJournal[]
  attendances    InternshipAttendance[]
  grades         InternshipGrade[]

  @@map("internships")
}

model InternshipAssessmentComponent {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  weight      Float    @default(1.0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grades      InternshipGrade[]

  @@map("internship_assessment_components")
}

model InternshipGrade {
  id           Int                         @id @default(autoincrement())
  internshipId Int
  componentId  Int
  score        Float

  internship   Internship                  @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  component    InternshipAssessmentComponent @relation(fields: [componentId], references: [id])

  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@unique([internshipId, componentId])
  @@map("internship_grades")
}

model InternshipJournal {
  id           Int                @id @default(autoincrement())
  internshipId Int
  date         DateTime
  activity     String             @db.Text
  imageUrl     String?
  status       VerificationStatus @default(PENDING)
  feedback     String?

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  internship   Internship         @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@map("internship_journals")
}

model InternshipAttendance {
  id           Int              @id @default(autoincrement())
  internshipId Int
  date         DateTime
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  imageUrl     String?
  latitude     Float?
  longitude    Float?
  note         String?

  internship   Internship       @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([internshipId, date])
  @@map("internship_attendances")
}

enum InternshipStatus {
  PROPOSED
  WAITING_ACCEPTANCE_LETTER
  APPROVED
  ACTIVE
  REPORT_SUBMITTED
  DEFENSE_SCHEDULED
  DEFENSE_COMPLETED
  COMPLETED
  REJECTED
  CANCELED
}

