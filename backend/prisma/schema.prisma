generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int                            @id @default(autoincrement())
  username                 String                         @unique
  password                 String
  name                     String
  role                     Role
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt
  nip                      String?
  nis                      String?
  gender                   Gender?
  email                    String?
  phone                    String?
  address                  String?
  photo                    String?
  classId                  Int?
  additionalDuties         AdditionalDuty[]
  birthDate                DateTime?
  birthPlace               String?
  nisn                     String?                        @unique
  studentStatus            StudentStatus                  @default(ACTIVE)
  verificationCode         String?
  verificationExpires      DateTime?
  verificationMethod       VerificationMethod             @default(NONE)
  verificationStatus       VerificationStatus             @default(PENDING)
  appointmentDate          DateTime?
  appointmentDecree        String?
  dusun                    String?
  employeeStatus           String?
  institution              String?
  motherName               String?
  nik                      String?
  nuptk                    String?
  postalCode               String?
  ptkType                  String?
  rt                       String?
  rw                       String?
  subdistrict              String?
  village                  String?
  childNumber              Int?
  fatherIncome             String?
  fatherName               String?
  fatherOccupation         String?
  guardianName             String?
  guardianOccupation       String?
  guardianPhone            String?
  motherIncome             String?
  motherOccupation         String?
  religion                 String?
  siblingsCount            Int?
  preferences              Json?
  examinerMajorId          Int?
  assignments              Assignment[]
  attendances              AttendanceRecord[]
  approvedBudgets          BudgetRequest[]                @relation("BudgetApprover")
  assignedBudgets          BudgetRequest[]                @relation("BudgetAssignedApprover")
  requestedBudgets         BudgetRequest[]                @relation("BudgetRequester")
  teacherClasses           Class[]                        @relation("ClassTeacher")
  cpTpAnalyses             CpTpAnalysis[]
  dailyAttendances         DailyAttendance[]
  ekskulEnrollments        EkstrakurikulerEnrollment[]
  examAnswers              ExamAnswer[]
  createdExamPackets       ExamPacket[]                   @relation("ExamAuthor")
  proctoringReports        ExamProctoringReport[]
  proctoredExams           ExamSchedule[]                 @relation("ExamProctor")
  examScores               ExamScore[]
  assignedSittings         ExamSittingStudent[]
  proctoredSittings        ExamSitting[]                  @relation("SittingProctor")
  materials                Material[]
  notifications            Notification[]
  p5Assessments            P5Assessment[]
  payments                 Payment[]
  pklAssessments           PklAssessment[]
  reportNotes              ReportNote[]
  achievements             StudentAchievement[]
  examSessions             StudentExamSession[]
  studentGrades            StudentGrade[]
  submissions              Submission[]
  teacherAssignments       TeacherAssignment[]
  documents                TeacherDocument[]
  teachingDevices          TeachingDevice[]
  trainingSubmissions      TrainingAssignmentSubmission[]
  trainingClassesTeaching  TrainingClass[]                @relation("TrainingInstructor")
  trainingEnrollments      TrainingEnrollment[]
  trainingExamAnswers      TrainingExamAnswer[]
  trainingExamScores       TrainingExamScore[]
  ukkAssessmentsAsExaminer UkkAssessment[]                @relation("AssessmentExaminer")
  ukkAssessmentsAsStudent  UkkAssessment[]                @relation("StudentUkk")
  createdUkkSchemes        UkkScheme[]                    @relation("SchemeCreator")
  studentClass             Class?                         @relation("StudentClass", fields: [classId], references: [id])
  examinerMajor            Major?                         @relation("ExaminerMajor", fields: [examinerMajorId], references: [id])
  approvedWorkPrograms     WorkProgram[]                  @relation("WorkProgramApprover")
  ekskulTutorAssignments   EkstrakurikulerTutorAssignment[]
  ledClasses               Class[]                        @relation("ClassPresident")
  assignedWorkPrograms     WorkProgram[]                  @relation("WorkProgramAssignedApprover")
  workPrograms             WorkProgram[]                  @relation("WorkProgramOwner")
  managedMajors            Major[]                        @relation("MajorHeads")
  children                 User[]                         @relation("ParentChildren")
  parents                  User[]                         @relation("ParentChildren")
  assignedUkkSchemes       UkkScheme[]                    @relation("SchemeAssignedExaminers")
  behaviors                StudentBehavior[]
  studentExamRestrictions  StudentExamRestriction[]
  studentPermissions       StudentPermission[]            @relation("StudentPermissions")
  approvedPermissions      StudentPermission[]            @relation("PermissionApprover")
  createdQuestionBanks     QuestionBank[]                 @relation("BankAuthor")
  
  // Internship Relations
  internships              Internship[]                   @relation("StudentInternship")
  guidedInternships        Internship[]                   @relation("TeacherInternship")
  examinedInternships      Internship[]                   @relation("ExaminerInternship")

  @@map("users")
}

model StudentBehavior {
  id             Int          @id @default(autoincrement())
  studentId      Int
  classId        Int
  academicYearId Int
  date           DateTime
  type           BehaviorType
  category       String?
  description    String
  point          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  student        User         @relation(fields: [studentId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@map("student_behaviors")
}

model StudentExamRestriction {
  id             Int          @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  semester       Semester
  examType       ExamType
  isBlocked      Boolean      @default(false)
  reason         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  student        User         @relation(fields: [studentId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId, semester, examType])
  @@map("student_exam_restrictions")
}

enum BehaviorType {
  POSITIVE
  NEGATIVE
}

model AcademicYear {
  id                 Int                 @id @default(autoincrement())
  name               String              @unique
  isActive           Boolean             @default(false)
  pklEligibleGrades  String?             // Comma separated grades: "XI,XII"
  createdAt          DateTime            @default(now())
  semester1End       DateTime
  semester1Start     DateTime
  semester2End       DateTime
  semester2Start     DateTime
  updatedAt          DateTime            @updatedAt
  academicEvents     AcademicEvent[]
  assignments        Assignment[]
  attendances        Attendance[]
  budgetRequests     BudgetRequest[]
  classes            Class[]
  cpTpAnalyses       CpTpAnalysis[]
  dailyAttendances   DailyAttendance[]
  examPackets        ExamPacket[]
  examSchedules      ExamSchedule[]
  examSittings       ExamSitting[]
  exams              Exam[]
  materials          Material[]
  p5Projects         P5Project[]
  questionBanks      QuestionBank[]
  reportNotes        ReportNote[]
  scheduleEntries    ScheduleEntry[]
  scheduleTimeConfig ScheduleTimeConfig?
  studentGrades      StudentGrade[]
  subjectKkms        SubjectKKM[]
  teacherAssignments TeacherAssignment[]
  teachingDevices    TeachingDevice[]
  trainingClasses    TrainingClass[]
  ukkAssessments     UkkAssessment[]
  ukkSchemes         UkkScheme[]
  workPrograms       WorkProgram[]
  studentBehaviors   StudentBehavior[]
  studentExamRestrictions StudentExamRestriction[]
  studentPermissions      StudentPermission[]
  reportDates             ReportDate[]
  ekskulTutorAssignments EkstrakurikulerTutorAssignment[]
  ekskulEnrollments      EkstrakurikulerEnrollment[]
  internships            Internship[]

  @@map("academic_years")
}

model StudentPermission {
  id             Int              @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  type           PermissionType
  startDate      DateTime
  endDate        DateTime
  reason         String?
  fileUrl        String?
  status         ApprovalStatus   @default(PENDING)
  approvalNote   String?
  approvedById   Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  student        User             @relation("StudentPermissions", fields: [studentId], references: [id])
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  approvedBy     User?            @relation("PermissionApprover", fields: [approvedById], references: [id])

  @@map("student_permissions")
}

enum PermissionType {
  SICK
  PERMISSION
  OTHER
}

model ScheduleTimeConfig {
  id             Int          @id @default(autoincrement())
  academicYearId Int          @unique
  config         Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@map("schedule_time_configs")
}

model AcademicEvent {
  id             Int               @id @default(autoincrement())
  academicYearId Int
  title          String
  type           AcademicEventType
  startDate      DateTime
  endDate        DateTime
  semester       Semester?
  isHoliday      Boolean           @default(false)
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])

  @@map("academic_events")
}

model Major {
  id           Int           @id @default(autoincrement())
  name         String
  code         String        @unique
  description  String?
  classes      Class[]
  ukkSchemes   UkkScheme[]
  examiners    User[]        @relation("ExaminerMajor")
  workPrograms WorkProgram[]
  heads        User[]        @relation("MajorHeads")

  @@map("majors")
}

model Class {
  id                 Int                 @id @default(autoincrement())
  name               String
  level              String
  majorId            Int
  academicYearId     Int
  teacherId          Int?
  presidentId        Int?
  assignments        Assignment[]
  attendances        Attendance[]
  academicYear       AcademicYear        @relation(fields: [academicYearId], references: [id])
  major              Major               @relation(fields: [majorId], references: [id])
  teacher            User?               @relation("ClassTeacher", fields: [teacherId], references: [id])
  president          User?               @relation("ClassPresident", fields: [presidentId], references: [id])
  dailyAttendances   DailyAttendance[]
  examSchedules      ExamSchedule[]
  materials          Material[]
  scheduleEntries    ScheduleEntry[]
  teacherAssignments TeacherAssignment[]
  students           User[]              @relation("StudentClass")
  studentBehaviors   StudentBehavior[]

  @@map("classes")
}

model Subject {
  id                 Int                 @id @default(autoincrement())
  name               String
  code               String              @unique
  description        String?
  parentId           Int?
  categoryId         Int?
  assignments        Assignment[]
  attendances        Attendance[]
  cpTpAnalyses       CpTpAnalysis[]
  examPackets        ExamPacket[]
  examSchedules      ExamSchedule[]
  exams              Exam[]
  gradeComponents    GradeComponent[]
  materials          Material[]
  questionBanks      QuestionBank[]
  reportGrades       ReportGrade[]
  studentGrades      StudentGrade[]
  kkms               SubjectKKM[]
  category           SubjectCategory?    @relation(fields: [categoryId], references: [id])
  parent             Subject?            @relation("SubjectHierarchy", fields: [parentId], references: [id])
  children           Subject[]           @relation("SubjectHierarchy")
  teacherAssignments TeacherAssignment[]
  teachingDevices    TeachingDevice[]
  ukkAssessments     UkkAssessment[]
  ukkSchemes         UkkScheme[]

  @@map("subjects")
}

model SubjectCategory {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  subjects    Subject[]

  @@map("subject_categories")
}

model SubjectKKM {
  id             Int           @id @default(autoincrement())
  subjectId      Int
  classLevel     String
  kkm            Int
  academicYearId Int?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  subject        Subject       @relation(fields: [subjectId], references: [id])

  @@unique([subjectId, classLevel, academicYearId])
  @@map("subject_kkms")
}

model TeacherAssignment {
  id                   Int             @id @default(autoincrement())
  teacherId            Int
  classId              Int
  subjectId            Int
  academicYearId       Int
  kkm                  Int             @default(75)
  competencyThresholds Json?
  scheduleEntries      ScheduleEntry[]
  academicYear         AcademicYear    @relation(fields: [academicYearId], references: [id])
  class                Class           @relation(fields: [classId], references: [id])
  subject              Subject         @relation(fields: [subjectId], references: [id])
  teacher              User            @relation(fields: [teacherId], references: [id])

  @@map("teacher_assignments")
}

model ScheduleEntry {
  id                  Int               @id @default(autoincrement())
  academicYearId      Int
  classId             Int
  teacherAssignmentId Int
  dayOfWeek           DayOfWeek
  period              Int
  room                String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  academicYear        AcademicYear      @relation(fields: [academicYearId], references: [id])
  class               Class             @relation(fields: [classId], references: [id])
  teacherAssignment   TeacherAssignment @relation(fields: [teacherAssignmentId], references: [id], onDelete: Cascade)

  @@unique([classId, academicYearId, dayOfWeek, period])
  @@map("schedule_entries")
}

model Material {
  id             Int           @id @default(autoincrement())
  title          String
  description    String?
  fileUrl        String?
  youtubeUrl     String?
  createdAt      DateTime      @default(now())
  subjectId      Int
  academicYearId Int?
  classId        Int?
  fileName       String?
  fileSize       Int?
  fileType       String?
  isPublished    Boolean       @default(true)
  teacherId      Int?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  class          Class?        @relation(fields: [classId], references: [id])
  subject        Subject       @relation(fields: [subjectId], references: [id])
  teacher        User?         @relation(fields: [teacherId], references: [id])

  @@map("materials")
}

model Assignment {
  id             Int          @id @default(autoincrement())
  title          String
  description    String?
  dueDate        DateTime
  createdAt      DateTime     @default(now())
  teacherId      Int
  subjectId      Int
  classId        Int
  academicYearId Int
  parentId       Int?
  allowResubmit  Boolean      @default(true)
  fileName       String?
  fileUrl        String?
  isPublished    Boolean      @default(true)
  maxScore       Int          @default(100)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  parent         Assignment?  @relation("AssignmentHierarchy", fields: [parentId], references: [id])
  children       Assignment[] @relation("AssignmentHierarchy")
  subject        Subject      @relation(fields: [subjectId], references: [id])
  teacher        User         @relation(fields: [teacherId], references: [id])
  submissions    Submission[]

  @@map("assignments")
}

model Submission {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  studentId    Int
  fileUrl      String?
  content      String?
  submittedAt  DateTime   @default(now())
  score        Float?
  feedback     String?
  fileName     String?
  fileSize     Int?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      User       @relation(fields: [studentId], references: [id])

  @@map("submissions")
}

model QuestionBank {
  id             Int          @id @default(autoincrement())
  title          String
  subjectId      Int
  classLevel     String?
  academicYearId Int
  semester       Semester     @default(ODD)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])
  questions      Question[]
  authorId       Int?
  author         User?        @relation("BankAuthor", fields: [authorId], references: [id])

  @@map("question_banks")
}

model Question {
  id        Int          @id @default(autoincrement())
  bankId    Int
  type      QuestionType
  content   String
  options   Json?
  answerKey String?
  points    Int          @default(1)
  mediaUrl  String?
  mediaType String?
  bank      QuestionBank @relation(fields: [bankId], references: [id])

  @@map("questions")
}

model Exam {
  id             Int          @id @default(autoincrement())
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  duration       Int
  subjectId      Int
  academicYearId Int
  questions      Json?
  category       ExamCategory @default(ACADEMIC)
  semester       Semester     @default(ODD)
  examAnswers    ExamAnswer[]
  examScores     ExamScore[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  subject        Subject      @relation(fields: [subjectId], references: [id])

  @@map("exams")
}

model ExamAnswer {
  id          Int      @id @default(autoincrement())
  examId      Int
  studentId   Int
  answers     Json
  submittedAt DateTime @default(now())
  exam        Exam     @relation(fields: [examId], references: [id])
  student     User     @relation(fields: [studentId], references: [id])

  @@map("exam_answers")
}

model ExamScore {
  id        Int     @id @default(autoincrement())
  examId    Int
  studentId Int
  score     Float
  grade     String?
  exam      Exam    @relation(fields: [examId], references: [id])
  student   User    @relation(fields: [studentId], references: [id])

  @@map("exam_scores")
}

model Attendance {
  id             Int                @id @default(autoincrement())
  date           DateTime
  classId        Int
  subjectId      Int
  academicYearId Int
  records        AttendanceRecord[]
  academicYear   AcademicYear       @relation(fields: [academicYearId], references: [id])
  class          Class              @relation(fields: [classId], references: [id])
  subject        Subject            @relation(fields: [subjectId], references: [id])

  @@map("attendances")
}

model AttendanceRecord {
  id           Int              @id @default(autoincrement())
  attendanceId Int
  studentId    Int
  status       AttendanceStatus
  note         String?
  attendance   Attendance       @relation(fields: [attendanceId], references: [id])
  student      User             @relation(fields: [studentId], references: [id])

  @@map("attendance_records")
}

model DailyAttendance {
  id             Int              @id @default(autoincrement())
  date           DateTime
  studentId      Int
  classId        Int
  academicYearId Int
  status         AttendanceStatus
  note           String?
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  class          Class            @relation(fields: [classId], references: [id])
  student        User             @relation(fields: [studentId], references: [id])

  @@map("daily_attendances")
}

model GradeComponent {
  id            Int                @id @default(autoincrement())
  name          String
  weight        Float
  isActive      Boolean            @default(true)
  subjectId     Int
  type          GradeComponentType
  subject       Subject            @relation(fields: [subjectId], references: [id])
  studentGrades StudentGrade[]

  @@map("grade_components")
}

model StudentGrade {
  id             Int            @id @default(autoincrement())
  studentId      Int
  subjectId      Int
  componentId    Int
  academicYearId Int
  score          Float
  nf1            Float?
  nf2            Float?
  nf3            Float?
  nf4            Float?
  nf5            Float?
  nf6            Float?
  semester       Semester
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  component      GradeComponent @relation(fields: [componentId], references: [id])
  student        User           @relation(fields: [studentId], references: [id])
  subject        Subject        @relation(fields: [subjectId], references: [id])

  @@map("student_grades")
}

model ReportDate {
  id             Int          @id @default(autoincrement())
  academicYearId Int
  semester       Semester
  reportType     ExamType     // SBTS, SAS, SAT
  place          String       // e.g. "Bekasi"
  date           DateTime     // e.g. 2024-12-20
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([academicYearId, semester, reportType])
  @@map("report_dates")
}

model ReportGrade {
  id             Int      @id @default(autoincrement())
  studentId      Int
  subjectId      Int
  academicYearId Int
  finalScore     Float
  predicate      String?
  description    String?  @map("competency_desc")
  formatifScore  Float?   @map("formatif_score")
  sasScore       Float?   @map("sas_score")
  sbtsScore      Float?   @map("sbts_score")
  semester       Semester
  usScore        Float?
  subject        Subject  @relation(fields: [subjectId], references: [id])

  @@map("report_grades")
}

model ReportNote {
  id             Int          @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  note           String
  type           String
  semester       Semester
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  student        User         @relation(fields: [studentId], references: [id])

  @@map("report_notes")
}

model Ekstrakurikuler {
  id          Int                         @id @default(autoincrement())
  name        String
  description String?
  enrollments EkstrakurikulerEnrollment[]
  tutorAssignments EkstrakurikulerTutorAssignment[]

  @@map("ekstrakurikulers")
}

model EkstrakurikulerEnrollment {
  id             Int             @id @default(autoincrement())
  ekskulId       Int
  studentId      Int
  academicYearId Int

  grade          String?
  description    String?

  gradeSbtsOdd   String?
  descSbtsOdd    String?
  gradeSas       String?
  descSas        String?
  gradeSbtsEven  String?
  descSbtsEven   String?
  gradeSat       String?
  descSat        String?

  ekskul         Ekstrakurikuler @relation(fields: [ekskulId], references: [id])
  student        User            @relation(fields: [studentId], references: [id])
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])

  @@map("ekstrakurikuler_enrollments")
}

model EkstrakurikulerTutorAssignment {
  id             Int             @id @default(autoincrement())
  tutorId        Int
  ekskulId       Int
  academicYearId Int
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  tutor          User            @relation(fields: [tutorId], references: [id])
  ekskul         Ekstrakurikuler @relation(fields: [ekskulId], references: [id])
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  
  @@unique([tutorId, ekskulId, academicYearId], map: "ekstrakurikuler_tutor_assignments_tutorId_ekskulId_academic_key")
  @@map("ekstrakurikuler_tutor_assignments")
}

model P5Project {
  id             Int            @id @default(autoincrement())
  title          String
  description    String?
  theme          String
  academicYearId Int
  assessments    P5Assessment[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@map("p5_projects")
}

model P5Assessment {
  id        Int       @id @default(autoincrement())
  projectId Int
  studentId Int
  score     String?
  note      String?
  project   P5Project @relation(fields: [projectId], references: [id])
  student   User      @relation(fields: [studentId], references: [id])

  @@map("p5_assessments")
}

model PklAssessment {
  id           Int     @id @default(autoincrement())
  studentId    Int
  industryName String
  duration     String
  score        Float
  predicate    String?
  student      User    @relation(fields: [studentId], references: [id])

  @@map("pkl_assessments")
}

model StudentAchievement {
  id        Int     @id @default(autoincrement())
  studentId Int
  name      String
  level     String
  year      Int
  rank      String?
  organizer String?
  student   User    @relation(fields: [studentId], references: [id])

  @@map("student_achievements")
}

model TrainingClass {
  id             Int                  @id @default(autoincrement())
  description    String?
  academicYearId Int
  endDate        DateTime?
  instructorId   Int?
  startDate      DateTime?
  isActive       Boolean              @default(true)
  maxCapacity    Int?
  name           String
  assignments    TrainingAssignment[]
  academicYear   AcademicYear         @relation(fields: [academicYearId], references: [id])
  instructor     User?                @relation("TrainingInstructor", fields: [instructorId], references: [id])
  enrollments    TrainingEnrollment[]
  exams          TrainingExam[]
  materials      TrainingMaterial[]

  @@map("training_classes")
}

model TrainingEnrollment {
  id         Int           @id @default(autoincrement())
  trainingId Int
  studentId  Int
  createdAt  DateTime      @default(now())
  student    User          @relation(fields: [studentId], references: [id])
  training   TrainingClass @relation(fields: [trainingId], references: [id])

  @@map("training_enrollments")
}

model TrainingMaterial {
  id         Int           @id @default(autoincrement())
  title      String
  trainingId Int
  fileUrl    String?
