generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                 Int                                 @id @default(autoincrement())
  username                                           String                              @unique
  password                                           String
  name                                               String
  role                                               Role
  createdAt                                          DateTime                            @default(now())
  updatedAt                                          DateTime                            @updatedAt
  nip                                                String?
  nis                                                String?
  gender                                             Gender?
  email                                              String?
  phone                                              String?
  address                                            String?
  photo                                              String?
  classId                                            Int?
  additionalDuties                                   AdditionalDuty[]
  birthDate                                          DateTime?
  birthPlace                                         String?
  citizenship                                        String?
  maritalStatus                                      String?
  nisn                                               String?                             @unique
  studentStatus                                      StudentStatus                       @default(ACTIVE)
  verificationCode                                   String?
  verificationExpires                                DateTime?
  verificationMethod                                 VerificationMethod                  @default(NONE)
  verificationStatus                                 VerificationStatus                  @default(PENDING)
  appointmentDate                                    DateTime?
  appointmentDecree                                  String?
  assignmentDate                                     DateTime?
  assignmentDecree                                   String?
  dusun                                              String?
  employeeActiveStatus                               String?
  employeeStatus                                     String?
  institution                                        String?
  highestEducation                                   String?
  studyProgram                                       String?
  motherName                                         String?
  motherNik                                          String?
  nik                                                String?
  familyCardNumber                                   String?
  nuptk                                              String?
  postalCode                                         String?
  ptkType                                            String?
  province                                           String?
  provinceCode                                       String?
  salarySource                                       String?
  cityRegency                                        String?
  cityRegencyCode                                    String?
  rt                                                 String?
  rw                                                 String?
  subdistrict                                        String?
  subdistrictCode                                    String?
  village                                            String?
  villageCode                                        String?
  childNumber                                        Int?
  familyStatus                                       String?
  livingWith                                         String?
  transportationMode                                 String?
  kipNumber                                          String?
  pkhNumber                                          String?
  kksNumber                                          String?
  fatherIncome                                       String?
  fatherNik                                          String?
  fatherName                                         String?
  fatherOccupation                                   String?
  guardianName                                       String?
  guardianEducation                                  String?
  guardianOccupation                                 String?
  guardianPhone                                      String?
  motherEducation                                    String?
  motherIncome                                       String?
  motherOccupation                                   String?
  religion                                           String?
  siblingsCount                                      Int?
  fatherEducation                                    String?
  preferences                                        Json?
  examinerMajorId                                    Int?
  assignments                                        Assignment[]
  attendances                                        AttendanceRecord[]
  approvedBudgets                                    BudgetRequest[]                     @relation("BudgetApprover")
  assignedBudgets                                    BudgetRequest[]                     @relation("BudgetAssignedApprover")
  requestedBudgets                                   BudgetRequest[]                     @relation("BudgetRequester")
  confirmedBudgetRealizations                        BudgetRequest[]                     @relation("BudgetRealizationConfirmer")
  teacherClasses                                     Class[]                             @relation("ClassTeacher")
  cpTpAnalyses                                       CpTpAnalysis[]
  teachingResourceEntriesAuthored                    TeachingResourceEntry[]             @relation("TeachingResourceEntryAuthor")
  teachingResourceEntriesReviewed                    TeachingResourceEntry[]             @relation("TeachingResourceEntryReviewer")
  dailyAttendances                                   DailyAttendance[]
  ekskulEnrollments                                  EkstrakurikulerEnrollment[]
  examAnswers                                        ExamAnswer[]
  createdExamPackets                                 ExamPacket[]                        @relation("ExamAuthor")
  proctoringReports                                  ExamProctoringReport[]
  proctoredExams                                     ExamSchedule[]                      @relation("ExamProctor")
  examScores                                         ExamScore[]
  assignedSittings                                   ExamSittingStudent[]
  proctoredSittings                                  ExamSitting[]                       @relation("SittingProctor")
  materials                                          Material[]
  notifications                                      Notification[]
  mobilePushDevices                                  MobilePushDevice[]
  auditLogs                                          AuditLog[]
  p5Assessments                                      P5Assessment[]
  payments                                           Payment[]
  financeInvoices                                    FinanceInvoice[]                    @relation("FinanceInvoiceStudent")
  financePayments                                    FinancePayment[]                    @relation("FinancePaymentStudent")
  verifiedFinancePayments                            FinancePayment[]                    @relation("FinancePaymentVerifiedBy")
  financeCreditBalance                               FinanceCreditBalance?               @relation("FinanceCreditBalanceStudent")
  financeCreditTransactions                          FinanceCreditTransaction[]          @relation("FinanceCreditTransactionStudent")
  financeRefunds                                     FinanceRefund[]                     @relation("FinanceRefundStudent")
  financeWriteOffRequestsAsStudent                   FinanceWriteOffRequest[]            @relation("FinanceWriteOffStudent")
  financePaymentReversalRequestsAsStudent            FinancePaymentReversalRequest[]     @relation("FinancePaymentReversalStudent")
  createdFinanceInvoices                             FinanceInvoice[]                    @relation("FinanceInvoiceCreator")
  createdFinancePayments                             FinancePayment[]                    @relation("FinancePaymentCreator")
  createdFinanceCreditTransactions                   FinanceCreditTransaction[]          @relation("FinanceCreditTransactionCreator")
  createdFinanceRefunds                              FinanceRefund[]                     @relation("FinanceRefundCreator")
  createdFinanceComponents                           FinanceComponent[]                  @relation("FinanceComponentCreator")
  createdFinanceTariffRules                          FinanceTariffRule[]                 @relation("FinanceTariffRuleCreator")
  financeAdjustmentRules                             FinanceAdjustmentRule[]             @relation("FinanceAdjustmentRuleStudent")
  createdFinanceAdjustmentRules                      FinanceAdjustmentRule[]             @relation("FinanceAdjustmentRuleCreator")
  createdFinanceWriteOffRequests                     FinanceWriteOffRequest[]            @relation("FinanceWriteOffRequester")
  headTuDecidedFinanceWriteOffs                      FinanceWriteOffRequest[]            @relation("FinanceWriteOffHeadTuDecisionBy")
  principalDecidedFinanceWriteOffs                   FinanceWriteOffRequest[]            @relation("FinanceWriteOffPrincipalDecisionBy")
  appliedFinanceWriteOffs                            FinanceWriteOffRequest[]            @relation("FinanceWriteOffAppliedBy")
  createdFinancePaymentReversalRequests              FinancePaymentReversalRequest[]     @relation("FinancePaymentReversalRequester")
  headTuDecidedFinancePaymentReversals               FinancePaymentReversalRequest[]     @relation("FinancePaymentReversalHeadTuDecisionBy")
  principalDecidedFinancePaymentReversals            FinancePaymentReversalRequest[]     @relation("FinancePaymentReversalPrincipalDecisionBy")
  appliedFinancePaymentReversals                     FinancePaymentReversalRequest[]     @relation("FinancePaymentReversalAppliedBy")
  openedFinanceCashSessions                          FinanceCashSession[]                @relation("FinanceCashSessionOpenedBy")
  closedFinanceCashSessions                          FinanceCashSession[]                @relation("FinanceCashSessionClosedBy")
  headTuReviewedFinanceCashSessions                  FinanceCashSession[]                @relation("FinanceCashSessionHeadTuDecisionBy")
  principalReviewedFinanceCashSessions               FinanceCashSession[]                @relation("FinanceCashSessionPrincipalDecisionBy")
  requestedFinanceClosingPeriods                     FinanceClosingPeriod[]              @relation("FinanceClosingPeriodRequestedBy")
  headTuReviewedFinanceClosingPeriods                FinanceClosingPeriod[]              @relation("FinanceClosingPeriodHeadTuDecisionBy")
  principalReviewedFinanceClosingPeriods             FinanceClosingPeriod[]              @relation("FinanceClosingPeriodPrincipalDecisionBy")
  closedFinanceClosingPeriods                        FinanceClosingPeriod[]              @relation("FinanceClosingPeriodClosedBy")
  reopenedFinanceClosingPeriods                      FinanceClosingPeriod[]              @relation("FinanceClosingPeriodReopenedBy")
  createdFinanceClosingPeriodReopenRequests          FinanceClosingPeriodReopenRequest[] @relation("FinanceClosingPeriodReopenRequester")
  headTuDecidedFinanceClosingPeriodReopenRequests    FinanceClosingPeriodReopenRequest[] @relation("FinanceClosingPeriodReopenHeadTuDecisionBy")
  principalDecidedFinanceClosingPeriodReopenRequests FinanceClosingPeriodReopenRequest[] @relation("FinanceClosingPeriodReopenPrincipalDecisionBy")
  appliedFinanceClosingPeriodReopenRequests          FinanceClosingPeriodReopenRequest[] @relation("FinanceClosingPeriodReopenAppliedBy")
  createdFinanceBankAccounts                         FinanceBankAccount[]                @relation("FinanceBankAccountCreatedBy")
  createdFinanceBankReconciliations                  FinanceBankReconciliation[]         @relation("FinanceBankReconciliationCreatedBy")
  finalizedFinanceBankReconciliations                FinanceBankReconciliation[]         @relation("FinanceBankReconciliationFinalizedBy")
  createdFinanceBankStatementEntries                 FinanceBankStatementEntry[]         @relation("FinanceBankStatementEntryCreatedBy")
  pklAssessments                                     PklAssessment[]
  reportNotes                                        ReportNote[]
  achievements                                       StudentAchievement[]
  examSessions                                       StudentExamSession[]
  studentGrades                                      StudentGrade[]
  scoreEntries                                       StudentScoreEntry[]
  submissions                                        Submission[]
  teacherAssignments                                 TeacherAssignment[]
  documents                                          TeacherDocument[]
  teachingDevices                                    TeachingDevice[]
  trainingSubmissions                                TrainingAssignmentSubmission[]
  trainingClassesTeaching                            TrainingClass[]                     @relation("TrainingInstructor")
  trainingEnrollments                                TrainingEnrollment[]
  trainingExamAnswers                                TrainingExamAnswer[]
  trainingExamScores                                 TrainingExamScore[]
  ukkAssessmentsAsExaminer                           UkkAssessment[]                     @relation("AssessmentExaminer")
  ukkAssessmentsAsStudent                            UkkAssessment[]                     @relation("StudentUkk")
  createdUkkSchemes                                  UkkScheme[]                         @relation("SchemeCreator")
  studentClass                                       Class?                              @relation("StudentClass", fields: [classId], references: [id])
  examinerMajor                                      Major?                              @relation("ExaminerMajor", fields: [examinerMajorId], references: [id])
  approvedWorkPrograms                               WorkProgram[]                       @relation("WorkProgramApprover")
  ekskulTutorAssignments                             EkstrakurikulerTutorAssignment[]
  ledClasses                                         Class[]                             @relation("ClassPresident")
  assignedWorkPrograms                               WorkProgram[]                       @relation("WorkProgramAssignedApprover")
  workPrograms                                       WorkProgram[]                       @relation("WorkProgramOwner")
  managedMajors                                      Major[]                             @relation("MajorHeads")
  children                                           User[]                              @relation("ParentChildren")
  parents                                            User[]                              @relation("ParentChildren")
  assignedUkkSchemes                                 UkkScheme[]                         @relation("SchemeAssignedExaminers")
  behaviors                                          StudentBehavior[]
  bpbkCounselingAsStudent                            BpBkCounseling[]                    @relation("BpBkCounselingStudent")
  bpbkCounselingAsCounselor                          BpBkCounseling[]                    @relation("BpBkCounselingCounselor")
  studentExamRestrictions                            StudentExamRestriction[]
  studentExamProgramRestrictions                     StudentExamProgramRestriction[]
  studentPermissions                                 StudentPermission[]                 @relation("StudentPermissions")
  academicMemberships                                StudentAcademicMembership[]
  promotionRunsCreated                               PromotionRun[]                      @relation("PromotionRunCreatedBy")
  promotionRunItems                                  PromotionRunItem[]                  @relation("PromotionRunStudent")
  approvedPermissions                                StudentPermission[]                 @relation("PermissionApprover")
  createdQuestionBanks                               QuestionBank[]                      @relation("BankAuthor")
  budgetLpjInvoicesCreated                           BudgetLpjInvoice[]                  @relation("BudgetLpjInvoiceCreator")
  libraryBookLoansCreated                            LibraryBookLoan[]                   @relation("LibraryLoanCreator")
  libraryBookLoansBorrowed                           LibraryBookLoan[]                   @relation("LibraryLoanBorrower")
  officeLettersCreated                               OfficeLetter[]                      @relation("OfficeLetterCreator")
  officeLettersRecipient                             OfficeLetter[]                      @relation("OfficeLetterRecipient")
  managedInventoryRooms                              Room[]                              @relation("ManagedInventoryRooms")
  createdOsisElectionPeriods                         OsisElectionPeriod[]                @relation("OsisElectionCreator")
  osisElectionCandidacies                            OsisElectionCandidate[]             @relation("OsisElectionCandidateStudent")
  osisElectionVotes                                  OsisElectionVote[]                  @relation("OsisElectionVoter")
  createdOsisManagementPeriods                       OsisManagementPeriod[]              @relation("OsisManagementPeriodCreator")
  osisMemberships                                    OsisMembership[]                    @relation("OsisMembershipStudent")
  osisJoinRequests                                   OsisJoinRequest[]                   @relation("OsisJoinRequestStudent")
  processedOsisJoinRequests                          OsisJoinRequest[]                   @relation("OsisJoinRequestProcessedBy")
  gradedOsisAssessments                              OsisAssessment[]                    @relation("OsisAssessmentGradedBy")
  // Internship Relations
  internships                                        Internship[]                        @relation("StudentInternship")
  guidedInternships                                  Internship[]                        @relation("TeacherInternship")
  examinedInternships                                Internship[]                        @relation("ExaminerInternship")
  candidateAdmission                                 CandidateAdmission?
  candidateAdmissionAssessments                      CandidateAdmissionAssessment[]      @relation("CandidateAdmissionAssessments")
  jobApplicantProfile                                JobApplicantProfile?
  jobApplications                                    JobApplication[]                    @relation("JobApplications")
  jobApplicationAssessments                          JobApplicationAssessment[]          @relation("JobApplicationAssessments")

  @@map("users")
}

model StudentBehavior {
  id             Int          @id @default(autoincrement())
  studentId      Int
  classId        Int
  academicYearId Int
  date           DateTime
  type           BehaviorType
  category       String?
  description    String
  point          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  student      User             @relation(fields: [studentId], references: [id])
  class        Class            @relation(fields: [classId], references: [id])
  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id])
  counselings  BpBkCounseling[]

  @@map("student_behaviors")
}

model StudentExamRestriction {
  id             Int      @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  semester       Semester
  examType       ExamType
  isBlocked      Boolean  @default(false)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      User         @relation(fields: [studentId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId, semester, examType])
  @@map("student_exam_restrictions")
}

model StudentExamProgramRestriction {
  id             Int      @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  semester       Semester
  programCode    String
  isBlocked      Boolean  @default(false)
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      User         @relation(fields: [studentId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId, semester, programCode])
  @@index([academicYearId, semester, programCode])
  @@map("student_exam_program_restrictions")
}

enum BehaviorType {
  POSITIVE
  NEGATIVE
}

enum BpBkCounselingStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model AcademicYear {
  id                             Int                              @id @default(autoincrement())
  name                           String                           @unique
  isActive                       Boolean                          @default(false)
  pklEligibleGrades              String? // Comma separated grades: "XI,XII"
  createdAt                      DateTime                         @default(now())
  semester1End                   DateTime
  semester1Start                 DateTime
  semester2End                   DateTime
  semester2Start                 DateTime
  updatedAt                      DateTime                         @updatedAt
  academicEvents                 AcademicEvent[]
  assignments                    Assignment[]
  attendances                    Attendance[]
  budgetRequests                 BudgetRequest[]
  classes                        Class[]
  cpTpAnalyses                   CpTpAnalysis[]
  dailyAttendances               DailyAttendance[]
  examPackets                    ExamPacket[]
  examSchedules                  ExamSchedule[]
  examSittings                   ExamSitting[]
  exams                          Exam[]
  materials                      Material[]
  p5Projects                     P5Project[]
  questionBanks                  QuestionBank[]
  reportNotes                    ReportNote[]
  scheduleEntries                ScheduleEntry[]
  scheduleTimeConfig             ScheduleTimeConfig?
  studentGrades                  StudentGrade[]
  scoreEntries                   StudentScoreEntry[]
  subjectKkms                    SubjectKKM[]
  financeTariffRules             FinanceTariffRule[]
  financeAdjustmentRules         FinanceAdjustmentRule[]
  financeInvoices                FinanceInvoice[]
  financeRefunds                 FinanceRefund[]
  teacherAssignments             TeacherAssignment[]
  teachingDevices                TeachingDevice[]
  trainingClasses                TrainingClass[]
  ukkAssessments                 UkkAssessment[]
  ukkSchemes                     UkkScheme[]
  workPrograms                   WorkProgram[]
  studentBehaviors               StudentBehavior[]
  studentExamRestrictions        StudentExamRestriction[]
  studentExamProgramRestrictions StudentExamProgramRestriction[]
  studentPermissions             StudentPermission[]
  reportDates                    ReportDate[]
  ekskulTutorAssignments         EkstrakurikulerTutorAssignment[]
  ekskulEnrollments              EkstrakurikulerEnrollment[]
  ekskulGradeTemplates           EkstrakurikulerGradeTemplate[]
  internships                    Internship[]
  examProgramConfigs             ExamProgramConfig[]
  examGradeComponents            ExamGradeComponent[]
  examProgramSessions            ExamProgramSession[]
  osisElectionPeriods            OsisElectionPeriod[]
  osisManagementPeriods          OsisManagementPeriod[]
  osisGradeTemplates             OsisGradeTemplate[]
  osisAssessments                OsisAssessment[]
  osisJoinRequests               OsisJoinRequest[]
  teachingResourceProgramConfigs TeachingResourceProgramConfig[]
  teachingResourceEntries        TeachingResourceEntry[]
  bpbkCounselings                BpBkCounseling[]
  officeLetters                  OfficeLetter[]
  sourcePromotionMappings        PromotionClassMapping[]          @relation("PromotionSourceAcademicYear")
  targetPromotionMappings        PromotionClassMapping[]          @relation("PromotionTargetAcademicYear")
  sourcePromotionRuns            PromotionRun[]                   @relation("PromotionSourceRuns")
  targetPromotionRuns            PromotionRun[]                   @relation("PromotionTargetRuns")
  academicMemberships            StudentAcademicMembership[]

  @@map("academic_years")
}

model ExamProgramConfig {
  id                          Int                @id @default(autoincrement())
  academicYearId              Int
  code                        String
  baseType                    ExamType           @default(FORMATIF)
  baseTypeCode                String             @default("FORMATIF")
  gradeComponentType          GradeComponentType @default(FORMATIVE)
  gradeComponentTypeCode      String             @default("FORMATIVE")
  gradeComponentCode          String             @default("FORMATIVE")
  gradeComponentLabel         String?
  gradeEntryMode              GradeEntryMode     @default(SINGLE_SCORE)
  gradeEntryModeCode          String             @default("SINGLE_SCORE")
  displayLabel                String
  shortLabel                  String?
  description                 String?
  fixedSemester               Semester?
  displayOrder                Int                @default(0)
  isActive                    Boolean            @default(true)
  showOnTeacherMenu           Boolean            @default(true)
  showOnStudentMenu           Boolean            @default(true)
  targetClassLevels           String[]           @default([])
  allowedSubjectIds           Int[]              @default([])
  allowedAuthorIds            Int[]              @default([])
  financeClearanceMode        String             @default("BLOCK_ANY_OUTSTANDING")
  financeMinOutstandingAmount Float              @default(0)
  financeMinOverdueInvoices   Int                @default(1)
  financeClearanceNotes       String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  academicYear                AcademicYear       @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, code])
  @@index([academicYearId, displayOrder])
  @@map("exam_program_configs")
}

model ExamGradeComponent {
  id                  Int                 @id @default(autoincrement())
  academicYearId      Int
  code                String
  label               String
  type                GradeComponentType  @default(CUSTOM)
  typeCode            String              @default("CUSTOM")
  entryMode           GradeEntryMode      @default(SINGLE_SCORE)
  entryModeCode       String              @default("SINGLE_SCORE")
  reportSlot          ReportComponentSlot @default(NONE)
  reportSlotCode      String              @default("NONE")
  includeInFinalScore Boolean             @default(false)
  description         String?
  displayOrder        Int                 @default(0)
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  academicYear        AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, code])
  @@index([academicYearId, displayOrder])
  @@map("exam_grade_components")
}

model ExamProgramSession {
  id              Int            @id @default(autoincrement())
  academicYearId  Int
  programCode     String
  label           String
  normalizedLabel String
  displayOrder    Int            @default(0)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examSchedules   ExamSchedule[] @relation("ExamProgramSessionSchedules")
  examSittings    ExamSitting[]  @relation("ExamProgramSessionSittings")

  @@unique([academicYearId, programCode, normalizedLabel])
  @@index([academicYearId, programCode, displayOrder])
  @@map("exam_program_sessions")
}

model TeachingResourceProgramConfig {
  id                Int          @id @default(autoincrement())
  academicYearId    Int
  code              String
  displayLabel      String
  shortLabel        String?
  description       String?
  schema            Json?
  displayOrder      Int          @default(0)
  isActive          Boolean      @default(true)
  showOnTeacherMenu Boolean      @default(true)
  targetClassLevels String[]     @default([])
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  academicYear      AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([academicYearId, code])
  @@index([academicYearId, displayOrder])
  @@map("teaching_resource_program_configs")
}

model TeachingResourceEntry {
  id             Int                         @id @default(autoincrement())
  academicYearId Int
  teacherId      Int
  reviewerId     Int?
  programCode    String
  subjectId      Int?
  classLevel     String?
  className      String?
  title          String
  summary        String?
  content        Json
  tags           String[]                    @default([])
  status         TeachingResourceEntryStatus @default(DRAFT)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  academicYear   AcademicYear                @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  teacher        User                        @relation("TeachingResourceEntryAuthor", fields: [teacherId], references: [id], onDelete: Cascade)
  reviewer       User?                       @relation("TeachingResourceEntryReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([academicYearId, programCode, status])
  @@index([teacherId, academicYearId, programCode])
  @@index([submittedAt, status])
  @@map("teaching_resource_entries")
}

model StudentPermission {
  id             Int            @id @default(autoincrement())
  studentId      Int
  academicYearId Int
  type           PermissionType
  startDate      DateTime
  endDate        DateTime
  reason         String?
  fileUrl        String?
  status         ApprovalStatus @default(PENDING)
  approvalNote   String?
  approvedById   Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  student      User         @relation("StudentPermissions", fields: [studentId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  approvedBy   User?        @relation("PermissionApprover", fields: [approvedById], references: [id])

  @@map("student_permissions")
}

model BpBkCounseling {
  id                 Int                  @id @default(autoincrement())
  studentId          Int
  classId            Int
  academicYearId     Int
  counselorId        Int
  behaviorId         Int?
  sessionDate        DateTime
  issueSummary       String
  counselingNote     String?
  followUpPlan       String?
  summonParent       Boolean              @default(false)
  summonDate         DateTime?
  summonLetterNumber String?
  status             BpBkCounselingStatus @default(OPEN)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  student      User             @relation("BpBkCounselingStudent", fields: [studentId], references: [id])
  counselor    User             @relation("BpBkCounselingCounselor", fields: [counselorId], references: [id])
  class        Class            @relation(fields: [classId], references: [id])
  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  behavior     StudentBehavior? @relation(fields: [behaviorId], references: [id], onDelete: SetNull)

  @@index([academicYearId, classId, studentId])
  @@index([academicYearId, status, summonParent])
  @@map("bpbk_counselings")
}

enum PermissionType {
  SICK
  PERMISSION
  OTHER
}

model ScheduleTimeConfig {
  id             Int          @id @default(autoincrement())
  academicYearId Int          @unique
  config         Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@map("schedule_time_configs")
}

model AcademicEvent {
  id             Int               @id @default(autoincrement())
  academicYearId Int
  title          String
  type           AcademicEventType
  startDate      DateTime
  endDate        DateTime
  semester       Semester?
  isHoliday      Boolean           @default(false)
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])

  @@map("academic_events")
}

model Major {
  id                     Int                     @id @default(autoincrement())
  name                   String
  code                   String                  @unique
  description            String?
  classes                Class[]
  candidateAdmissions    CandidateAdmission[]
  financeTariffRules     FinanceTariffRule[]
  financeAdjustmentRules FinanceAdjustmentRule[]
  ukkSchemes             UkkScheme[]
  examiners              User[]                  @relation("ExaminerMajor")
  workPrograms           WorkProgram[]
  heads                  User[]                  @relation("MajorHeads")

  @@map("majors")
}

model Class {
  id                      Int                         @id @default(autoincrement())
  name                    String
  level                   String
  majorId                 Int
  academicYearId          Int
  teacherId               Int?
  presidentId             Int?
  assignments             Assignment[]
  attendances             Attendance[]
  academicYear            AcademicYear                @relation(fields: [academicYearId], references: [id])
  major                   Major                       @relation(fields: [majorId], references: [id])
  teacher                 User?                       @relation("ClassTeacher", fields: [teacherId], references: [id])
  president               User?                       @relation("ClassPresident", fields: [presidentId], references: [id])
  dailyAttendances        DailyAttendance[]
  examSchedules           ExamSchedule[]
  materials               Material[]
