  targetAcademicYear   AcademicYear                @relation("PromotionTargetRuns", fields: [targetAcademicYearId], references: [id], onDelete: Cascade)
  createdBy            User?                       @relation("PromotionRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
