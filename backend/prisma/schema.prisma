  targetAcademicYear   AcademicYear    @relation("PromotionTargetAcademicYear", fields: [targetAcademicYearId], references: [id], onDelete: Cascade)
  sourceClass          Class           @relation("PromotionSourceClass", fields: [sourceClassId], references: [id], onDelete: Cascade)
  targetClass          Class?          @relation("PromotionTargetClass", fields: [targetClassId], references: [id], onDelete: SetNull)

