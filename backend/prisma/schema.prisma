  partnerInterviewAt DateTime?
  finalizedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  applicant   User                     @relation("JobApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  vacancy     JobVacancy               @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  profile     JobApplicantProfile?     @relation(fields: [profileId], references: [id], onDelete: SetNull)
  assessments JobApplicationAssessment[]

  @@unique([applicantId, vacancyId])
  @@index([status, appliedAt])
  @@index([vacancyId, status])
  @@map("job_applications")
}

model CandidateAdmissionAssessment {
  id           Int                            @id @default(autoincrement())
  admissionId  Int
  componentCode CandidateAssessmentComponentCode
  title        String
  sourceType   SelectionAssessmentSource     @default(MANUAL)
  score        Float?
  maxScore     Float                         @default(100)
  weight       Float                         @default(1)
  passingScore Float?
  notes        String?                       @db.Text
  assessedAt   DateTime?
  evaluatorId  Int?
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  admission CandidateAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  evaluator User?              @relation("CandidateAdmissionAssessments", fields: [evaluatorId], references: [id], onDelete: SetNull)

  @@unique([admissionId, componentCode])
  @@index([admissionId, componentCode])
  @@map("candidate_admission_assessments")
}

model JobApplicationAssessment {
  id          Int                           @id @default(autoincrement())
  applicationId Int
  stageCode   JobApplicationAssessmentStageCode
  title       String
  sourceType  SelectionAssessmentSource    @default(MANUAL)
  score       Float?
  maxScore    Float                        @default(100)
  weight      Float                        @default(1)
  passingScore Float?
  notes       String?                      @db.Text
  assessedAt  DateTime?
  evaluatorId Int?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  evaluator   User?          @relation("JobApplicationAssessments", fields: [evaluatorId], references: [id], onDelete: SetNull)

  @@unique([applicationId, stageCode])
  @@index([applicationId, stageCode])
  @@map("job_application_assessments")
}

enum CooperationStatus {
  AKTIF
  NON_AKTIF
  PROSES
}

enum LibraryBorrowerStatus {
  TEACHER
  STUDENT
}

enum LibraryReturnStatus {
  RETURNED
  NOT_RETURNED
}

// Inventory Module
model RoomCategory {
  id                   Int      @id @default(autoincrement())
  name                 String
  description          String?
  inventoryTemplateKey String?  @default("STANDARD")
  isDefault            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  rooms Room[]

  @@map("room_categories")
}

model Room {
  id          Int      @id @default(autoincrement())
  categoryId  Int? // Made optional for migration, will be required later
  managerUserId Int?
  name        String
  // type        RoomType  // Deprecated, replaced by categoryId
  capacity    Int?
  location    String?
  condition   String? // BAIK, RUSAK_RINGAN, RUSAK_BERAT
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category RoomCategory?   @relation(fields: [categoryId], references: [id])
  managerUser User?        @relation("ManagedInventoryRooms", fields: [managerUserId], references: [id], onDelete: SetNull)
  items    InventoryItem[]

  @@map("rooms")
}

// Enum RoomType Deprecated
// enum RoomType {
//   CLASSROOM
//   LAB
//   SPORTS
//   WORSHIP
//   OFFICE
//   OTHER
// }

model InventoryItem {
  id             Int       @id @default(autoincrement())
  roomId         Int
  name           String
  code           String?
  brand          String?
  quantity       Int       @default(0)
  goodQty        Int       @default(0)
  minorDamageQty Int       @default(0)
  majorDamageQty Int       @default(0)
  condition      String? // Deprecated, use specific qty fields
  purchaseDate   DateTime?
  price          Float?
  source         String?
  description    String?
  attributes     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("inventory_items")
}

model LibraryBookLoan {
  id                Int                   @id @default(autoincrement())
  borrowDate        DateTime
  borrowQty         Int                   @default(1)
  borrowerName      String
  borrowerStatus    LibraryBorrowerStatus
  classId           Int?
  bookTitle         String
  publishYear       Int?
  returnDate        DateTime?
  returnStatus      LibraryReturnStatus   @default(NOT_RETURNED)
  phoneNumber       String?
  createdById       Int?
  borrowerUserId    Int?
  overdueNotifiedAt DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  class             Class?                @relation(fields: [classId], references: [id])
  createdBy         User?                 @relation("LibraryLoanCreator", fields: [createdById], references: [id])
  borrowerUser      User?                 @relation("LibraryLoanBorrower", fields: [borrowerUserId], references: [id])

  @@index([borrowDate])
  @@index([borrowerStatus])
  @@index([classId])
  @@index([borrowerUserId])
  @@map("library_book_loans")
}

model LibraryLoanPolicy {
  id         Int      @id @default(1)
  finePerDay Int      @default(1000)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("library_loan_policy")
}
