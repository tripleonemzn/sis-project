model CandidateAdmission {
  id                                 Int                      @id @default(autoincrement())
  userId                             Int                      @unique
  registrationNumber                 String                   @unique
  desiredMajorId                     Int?
  previousSchool                     String?
  lastEducation                      String?
  parentName                         String?
  parentPhone                        String?
  domicileCity                       String?
  motivation                         String?                  @db.Text
  submissionNotes                    String?                  @db.Text
  reviewNotes                        String?                  @db.Text
  decisionTitle                      String?
  decisionSummary                    String?                  @db.Text
  decisionNextSteps                  String?                  @db.Text
  decisionPublishedAt                DateTime?
  decisionLetterId                   Int?                     @unique
  decisionLetterIssuedAt             DateTime?
  decisionLetterIssuedCity           String?
  decisionLetterSignerName           String?
  decisionLetterSignerPosition       String?
  decisionLetterOfficialUrl          String?
  decisionLetterOfficialOriginalName String?
  decisionLetterOfficialUploadedAt   DateTime?
  status                             CandidateAdmissionStatus @default(DRAFT)
  submittedAt                        DateTime?
  reviewedAt                         DateTime?
  acceptedAt                         DateTime?
  createdAt                          DateTime                 @default(now())
  updatedAt                          DateTime                 @updatedAt

  user           User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  desiredMajor   Major?                         @relation(fields: [desiredMajorId], references: [id], onDelete: SetNull)
  assessments    CandidateAdmissionAssessment[]
  decisionLetter OfficeLetter?                  @relation("CandidateAdmissionDecisionLetter", fields: [decisionLetterId], references: [id], onDelete: SetNull)

  @@index([status, submittedAt])
  @@index([desiredMajorId, status])
  @@map("candidate_admissions")
}

model JobApplicantProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  headline          String?
  phone             String?
  email             String?
  address           String?
  educationLevel    String?
  graduationYear    Int?
  schoolName        String?
  major             String?
  skills            String?  @db.Text
  experienceSummary String?  @db.Text
  cvUrl             String?
  portfolioUrl      String?
  linkedinUrl       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@map("job_applicant_profiles")
}

model JobApplication {
  id                   Int                  @id @default(autoincrement())
  applicantId          Int
  vacancyId            Int
  profileId            Int?
  status               JobApplicationStatus @default(SUBMITTED)
  coverLetter          String?              @db.Text
  expectedSalary       String?
  source               String?
  reviewerNotes        String?              @db.Text
  partnerReferenceCode String?
  partnerHandoffNotes  String?              @db.Text
  partnerDecisionNotes String?              @db.Text
  appliedAt            DateTime             @default(now())
  reviewedAt           DateTime?
  shortlistedAt        DateTime?
  partnerInterviewAt   DateTime?
  finalizedAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  applicant   User                       @relation("JobApplications", fields: [applicantId], references: [id], onDelete: Cascade)
  vacancy     JobVacancy                 @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  profile     JobApplicantProfile?       @relation(fields: [profileId], references: [id], onDelete: SetNull)
  assessments JobApplicationAssessment[]

  @@unique([applicantId, vacancyId])
  @@index([status, appliedAt])
  @@index([vacancyId, status])
  @@map("job_applications")
}

model CandidateAdmissionAssessment {
  id            Int                              @id @default(autoincrement())
  admissionId   Int
  componentCode CandidateAssessmentComponentCode
  title         String
  sourceType    SelectionAssessmentSource        @default(MANUAL)
  score         Float?
  maxScore      Float                            @default(100)
  weight        Float                            @default(1)
  passingScore  Float?
  notes         String?                          @db.Text
  assessedAt    DateTime?
  evaluatorId   Int?
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt

  admission CandidateAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  evaluator User?              @relation("CandidateAdmissionAssessments", fields: [evaluatorId], references: [id], onDelete: SetNull)

  @@unique([admissionId, componentCode])
  @@index([admissionId, componentCode])
  @@map("candidate_admission_assessments")
}

model JobApplicationAssessment {
  id            Int                               @id @default(autoincrement())
  applicationId Int
  stageCode     JobApplicationAssessmentStageCode
  title         String
  sourceType    SelectionAssessmentSource         @default(MANUAL)
  score         Float?
  maxScore      Float                             @default(100)
  weight        Float                             @default(1)
  passingScore  Float?
  notes         String?                           @db.Text
  assessedAt    DateTime?
  evaluatorId   Int?
  createdAt     DateTime                          @default(now())
  updatedAt     DateTime                          @updatedAt

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  evaluator   User?          @relation("JobApplicationAssessments", fields: [evaluatorId], references: [id], onDelete: SetNull)

  @@unique([applicationId, stageCode])
  @@index([applicationId, stageCode])
  @@map("job_application_assessments")
}

