{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "internal": {
      "distribution": "internal",
      "channel": "pilot",
      "android": {
        "buildType": "apk"
      }
    },
    "internal-live": {
      "distribution": "internal",
      "channel": "pilot-live",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "staging",
      "android": {
        "buildType": "apk"
      }
    },
    "play-internal": {
      "channel": "pilot-live",
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
