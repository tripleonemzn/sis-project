{
  "name": "sis-mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "audit:parity": "node ./scripts/audit-mobile-parity.js",
    "doctor": "npx expo-doctor",
    "readiness": "bash ./scripts/check-mobile-readiness.sh",
    "release:check": "bash ./scripts/check-release-config.sh",
    "check:all": "npm run readiness && npm run doctor && npm run typecheck",
    "check:release": "npm run release:check && npm run check:all",
    "build:android:internal": "npx eas-cli build -p android --profile internal",
    "build:android:internal:live": "npx eas-cli build -p android --profile internal-live",
    "build:android:internal:auto": "bash ./scripts/build-android-internal.sh",
    "update:pilot-live": "bash ../scripts/publish-mobile-ota-isolated.sh pilot-live",
    "update:pilot-live:auto": "bash ./scripts/publish-ota-live-auto.sh",
    "update:pilot": "bash ../scripts/publish-mobile-ota-isolated.sh pilot",
    "update:staging": "bash ../scripts/publish-mobile-ota-isolated.sh staging",
    "update:production": "bash ../scripts/publish-mobile-ota-isolated.sh production",
    "update:pilot:unsafe": "bash ./scripts/publish-ota-safe.sh pilot",
    "update:staging:unsafe": "bash ./scripts/publish-ota-safe.sh staging",
    "update:production:unsafe": "bash ./scripts/publish-ota-safe.sh production",
    "release:prepare": "bash ./scripts/prepare-internal-release.sh",
    "qa:install:adb": "bash ./scripts/install-apk-adb.sh",
    "version:bump:patch": "node ./scripts/bump-mobile-version.js patch",
    "version:bump:minor": "node ./scripts/bump-mobile-version.js minor",
    "version:bump:major": "node ./scripts/bump-mobile-version.js major"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.16",
    "axios": "^1.13.2",
    "expo": "~54.0.23",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.14",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "scheduler": "^0.26.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint": "^9.39.1",
    "typescript": "~5.9.3"
  }
}
